# ── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── AWS (chiro-digest-app credentials) ────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_APP_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_APP_SECRET_ACCESS_KEY
AWS_DEFAULT_REGION=us-west-2
S3_BUCKET=chiro-digest-userdata

# ── GitHub ────────────────────────────────────────────────────────────────
# Create a fine-grained PAT at https://github.com/settings/tokens
# Permissions needed: Contents (read + write) on chiro-digest repo
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=dryoung1029/chiro-digest

# ── Optional ──────────────────────────────────────────────────────────────
NCBI_EMAIL=dryoung1029@gmail.com
